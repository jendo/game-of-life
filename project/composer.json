{
  "name": "jendo/game-of-life",
  "description": "Game of Life",
  "authors": [
    {
      "name": "Michal Jenis",
      "email": "jenis.michal@gmail.com"
    }
  ],
  "type": "project",
  "license": "MIT",
  "require": {
    "php": ">=8.1",
    "symfony/console": "^6.0",
    "symfony/http-kernel": "^6",
    "symfony/config": "^6",
    "symfony/dependency-injection": "^6",
    "symfony/yaml": "^6"
  },
  "require-dev": {
    "squizlabs/php_codesniffer": "^3"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app"
    }
  },
  "minimum-stability": "stable",
  "scripts": {
    "phpcs": "./vendor/bin/phpcs -d memory_limit=512M --parallel=8 --colors --standard=PSR12 --extensions=php --encoding=utf-8 -sp ./app"
  }
}
