# Enable Docker CLI build for Docker Compose
COMPOSE_DOCKER_CLI_BUILD=1

# Enable Docker BuildKit, a modern build system for Docker images
DOCKER_BUILDKIT=1

TZ=Europe/Prague
XDEBUG_MODE=debug
XDEBUG_CONFIG='max_nesting_level=1000 client_port=9003 idekey=PHPSTORM log=/tmp/xdebug.log client_host=host.docker.internal'
